# ============================================================
# ARP Global Capital — Environment Configuration (EXAMPLE)
# Copy to `.env` and adjust. NEVER commit a real .env file.
# ============================================================

# --- Database ---
# SQLite by default (file lives in ./data, persisted via Docker volume).
DATABASE_URL=sqlite:////app/data/arp.db

# --- Authentication (JWT) ---
# Generate a strong secret in production, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-in-production-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- LLM Provider ---
# LLM_PROVIDER selects the orchestration backend:
#   ollama -> use local Ollama (default for the demo; no data leaves the machine)
#   mock   -> deterministic, model-free synthesis (used in CI/tests; never hard-fails)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
# Lightweight fallback model for weaker laptops: llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30

# --- Dashboard -> Backend ---
BACKEND_URL=http://backend:8000

# --- Seeding ---
# Fixed seed keeps mock data reproducible across runs/demos.
SEED_RANDOM_SEED=42
